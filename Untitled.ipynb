    "    \"\\n\",\n",
    "    \"# Count parameters\\n\",\n",
    "    \"total_params = sum(p.numel() for p in lora_layer.parameters())\\n\",\n",
    "    \"trainable_params = sum(p.numel() for p in lora_layer.parameters() if p.requires_grad)\\n\",\n",
